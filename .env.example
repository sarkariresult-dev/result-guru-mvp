# Supabase
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Site / App
NEXT_PUBLIC_APP_URL="https://resultguru.co.in"
NEXT_PUBLIC_APP_NAME="Result Guru"
NEXT_PUBLIC_APP_TAGLINE="India's trusted source for Sarkari Updates"
NODE_ENV="development"

# Analytics & Ads
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID="pub-XXXXXXXXXXXXXXXX"

# SEO / Search Verification
NEXT_PUBLIC_GSC_VERIFICATION="your-google-verification-code"
NEXT_PUBLIC_BING_VERIFICATION="your-bing-verification-code"
NEXT_PUBLIC_YANDEX_VERIFICATION="your-yandex-verification-code"

# Social Media
NEXT_PUBLIC_TWITTER_HANDLE="@ResultGuru247"

# Security / Crons
CRON_SECRET="your-cron-secret"
REVALIDATE_SECRET="your-revalidate-secret"

# Upstash Rate Limiting
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# AI Configuration
GOOGLE_GENAI_API_KEY="your-google-genai-api-key"
GOOGLE_GENAI_MODEL="gemini-3.5-flash"
GOOGLE_GENAI_TEMPERATURE="0.4"

# Google Indexing API (for instant URL indexing)
# Get these from Google Cloud Console → IAM → Service Accounts → Create Key (JSON)
# Then add the service account email as Owner in Google Search Console
GOOGLE_CLIENT_EMAIL="your-service-account@your-project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
